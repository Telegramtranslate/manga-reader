{
    "$schema":  "https://openapi.vercel.sh/vercel.json",
    "buildCommand":  "npm run build",
    "outputDirectory":  "public",
    "rewrites":  [
                     {
                         "source":  "/robots.txt",
                         "destination":  "/api/robots.txt"
                     },
                     {
                         "source":  "/sitemap.xml",
                         "destination":  "/api/sitemap.xml"
                     },
                     {
                         "source":  "/sitemap-pages.xml",
                         "destination":  "/api/sitemap-pages.xml"
                     },
                     {
                         "source":  "/sitemap-anime.xml",
                         "destination":  "/api/sitemap-anime.xml"
                     },
                     {
                         "source":  "/__/auth/:path*",
                         "destination":  "https://oauth-489621.firebaseapp.com/__/auth/:path*"
                     },
                     {
                         "source":  "/__/firebase/:path*",
                         "destination":  "https://oauth-489621.firebaseapp.com/__/firebase/:path*"
                     },
                     {
                         "source":  "/catalog",
                         "destination":  "/index.html"
                     },
                     {
                         "source":  "/ongoing",
                         "destination":  "/index.html"
                     },
                     {
                         "source":  "/top",
                         "destination":  "/index.html"
                     },
                     {
                         "source":  "/schedule",
                         "destination":  "/index.html"
                     },
                     {
                         "source":  "/search",
                         "destination":  "/index.html"
                     },
                     {
                         "source":  "/profile",
                         "destination":  "/index.html"
                     },
                     {
                         "source":  "/anime/:path*",
                         "destination":  "/api/anime-page?alias=:path*"
                     }
                 ],
    "headers":  [
                    {
                        "source":  "/",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/index.html",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/catalog",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/ongoing",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/top",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/schedule",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/search",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/profile",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/anime/(.*)",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store, max-age=0"
                                        }
                                    ]
                    },
                    {
                        "source":  "/(.*)",
                        "headers":  [
                                        {
                                            "key":  "X-Content-Type-Options",
                                            "value":  "nosniff"
                                        },
                                        {
                                            "key":  "X-Frame-Options",
                                            "value":  "SAMEORIGIN"
                                        },
                                        {
                                            "key":  "Strict-Transport-Security",
                                            "value":  "max-age=31536000; includeSubDomains; preload"
                                        },
                                        {
                                            "key":  "Referrer-Policy",
                                            "value":  "strict-origin-when-cross-origin"
                                        },
                                        {
                                            "key":  "Permissions-Policy",
                                            "value":  "camera=(), microphone=(), geolocation=(), browsing-topics=()"
                                        },
                                        {
                                            "key":  "Cross-Origin-Opener-Policy",
                                            "value":  "same-origin-allow-popups"
                                        },
                                        {
                                            "key":  "Content-Security-Policy",
                                            "value":  "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'sha256-PhQKImgGKn+WIU7ebDmYM9siFybi3iLHgCL1kAaA3rE=' https://www.gstatic.com https://www.google.com https://accounts.google.com https://apis.google.com; style-src 'self'; img-src 'self' data: blob: https://www.google.com https://www.gstatic.com https://lh3.googleusercontent.com https://st.kp.yandex.net https://kodik.info https://*.kodik.biz https://i.kodikres.com https://*.kodikres.com https://anilibria.top https://*.anilibria.top https://libria.fun https://*.libria.fun https://shiki.one https://*.shiki.one https://shikimori.io https://shikimori.one https://shikimori.me https://shikimori.org; media-src 'self' blob:; connect-src 'self' blob: https://www.google.com https://*.firebaseio.com https://*.googleapis.com https://www.gstatic.com https://apis.google.com https://oauth-489621.firebaseapp.com; frame-src 'self' https://www.google.com https://accounts.google.com https://apis.google.com https://oauth-489621.firebaseapp.com https://www.youtube.com https://player.vimeo.com https://kodik.info https://*.kodik.biz https://kodikplayer.com https://*.kodikplayer.com; worker-src 'self' blob:; font-src 'self' data: https:; manifest-src 'self'; form-action 'self' https://accounts.google.com; frame-ancestors 'self'; report-uri /api/csp-report; upgrade-insecure-requests"
                                        }
                                    ]
                    },
                    {
                        "source":  "/api/kodik",
                        "headers":  [
                                        {
                                            "key":  "CDN-Cache-Control",
                                            "value":  "max-age=120, stale-while-revalidate=3600"
                                        }
                                    ]
                    },
                    {
                        "source":  "/api/csp-report",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-store"
                                        }
                                    ]
                    }
                ]
}
