{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/anilibria/:path*",
      "destination": "https://anilibria.top/api/v1/:path*"
    },
    {
      "source": "/api/identity/:path*",
      "destination": "https://identitytoolkit.googleapis.com/v1/:path*?key=AIzaSyDSZh9ObtPBPRlNHgCAcA3a1u4pNXdvDgY"
    },
    {
      "source": "/api/securetoken",
      "destination": "https://securetoken.googleapis.com/v1/token?key=AIzaSyDSZh9ObtPBPRlNHgCAcA3a1u4pNXdvDgY"
    },
    {
      "source": "/api/anilibria-media/:path*",
      "destination": "https://cache.libria.fun/:path*"
    },
    {
      "source": "/catalog",
      "destination": "/index.html"
    },
    {
      "source": "/ongoing",
      "destination": "/index.html"
    },
    {
      "source": "/top",
      "destination": "/index.html"
    },
    {
      "source": "/schedule",
      "destination": "/index.html"
    },
    {
      "source": "/search",
      "destination": "/index.html"
    },
    {
      "source": "/profile",
      "destination": "/index.html"
    },
    {
      "source": "/anime/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" }
      ]
    },
    {
      "source": "/api/anilibria/:path*",
      "headers": [
        { "key": "x-vercel-enable-rewrite-caching", "value": "1" },
        { "key": "CDN-Cache-Control", "value": "max-age=120, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/api/anilibria-media/:path*",
      "headers": [
        { "key": "x-vercel-enable-rewrite-caching", "value": "1" },
        { "key": "CDN-Cache-Control", "value": "max-age=300, stale-while-revalidate=86400" }
      ]
    }
  ]
}
