{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/mangabuff",
      "destination": "https://mangabuff.ru/"
    },
    {
      "source": "/api/mangabuff/:path*",
      "destination": "https://mangabuff.ru/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/mangabuff",
      "headers": [
        { "key": "x-vercel-enable-rewrite-caching", "value": "1" },
        { "key": "CDN-Cache-Control", "value": "max-age=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/api/mangabuff/:path*",
      "headers": [
        { "key": "x-vercel-enable-rewrite-caching", "value": "1" },
        { "key": "CDN-Cache-Control", "value": "max-age=300, stale-while-revalidate=86400" }
      ]
    }
  ]
}
