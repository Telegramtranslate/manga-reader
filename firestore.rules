rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownerEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : "";
    }

    function ownerBaseShape(userId) {
      return request.resource.data.keys().hasAll(['uid', 'email', 'updatedAt']) &&
        request.resource.data.uid == userId &&
        request.resource.data.email is string &&
        request.resource.data.email == ownerEmail() &&
        request.resource.data.updatedAt == request.time;
    }

    function validFavorites(userId) {
      return ownerBaseShape(userId) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'items', 'updatedAt']) &&
        request.resource.data.keys().hasOnly(['uid', 'email', 'items', 'updatedAt']) &&
        request.resource.data.items is list &&
        request.resource.data.items.size() <= 120;
    }

    function validProgress(userId) {
      return ownerBaseShape(userId) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'items', 'updatedAt']) &&
        request.resource.data.keys().hasOnly(['uid', 'email', 'items', 'updatedAt']) &&
        request.resource.data.items is map &&
        request.resource.data.items.keys().size() <= 500;
    }

    function validSettings(userId) {
      return ownerBaseShape(userId) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'item', 'updatedAt']) &&
        request.resource.data.keys().hasOnly(['uid', 'email', 'item', 'updatedAt']) &&
        request.resource.data.item is map &&
        request.resource.data.item.keys().hasAll(['autoplayNext']) &&
        request.resource.data.item.keys().hasOnly(['autoplayNext', 'theme']) &&
        request.resource.data.item.autoplayNext is bool &&
        (
          !request.resource.data.item.keys().hasAny(['theme']) ||
          (
            request.resource.data.item.theme is string &&
            (
              request.resource.data.item.theme == 'dark' ||
              request.resource.data.item.theme == 'light'
            )
          )
        );
    }

    function validNotifications(userId) {
      return ownerBaseShape(userId) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'items', 'updatedAt']) &&
        request.resource.data.keys().hasOnly(['uid', 'email', 'items', 'updatedAt']) &&
        request.resource.data.items is list &&
        request.resource.data.items.size() <= 120;
    }

    function validNotificationState(userId) {
      return ownerBaseShape(userId) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'item', 'updatedAt']) &&
        request.resource.data.keys().hasOnly(['uid', 'email', 'item', 'updatedAt']) &&
        request.resource.data.item is map &&
        request.resource.data.item.keys().hasAll(['seenNewAnimeAliases', 'lastEpisodeByAlias']) &&
        request.resource.data.item.keys().hasOnly(['seenNewAnimeAliases', 'dismissedIds', 'lastEpisodeByAlias', 'initializedAt', 'lastScanAt']) &&
        request.resource.data.item.seenNewAnimeAliases is list &&
        request.resource.data.item.seenNewAnimeAliases.size() <= 240 &&
        (
          !('dismissedIds' in request.resource.data.item) ||
          (
            request.resource.data.item.dismissedIds is list &&
            request.resource.data.item.dismissedIds.size() <= 480
          )
        ) &&
        request.resource.data.item.lastEpisodeByAlias is map &&
        request.resource.data.item.lastEpisodeByAlias.keys().size() <= 240;
    }

    function adminClaim() {
      return signedIn() && request.auth.token.admin == true;
    }

    function validCommentCreate(alias) {
      return signedIn() &&
        request.resource.data.keys().hasAll(['alias', 'author', 'uid', 'body', 'createdAt']) &&
        request.resource.data.keys().hasOnly(['alias', 'author', 'uid', 'body', 'createdAt', 'clientId']) &&
        request.resource.data.alias == alias &&
        request.resource.data.author is string &&
        request.resource.data.author.size() > 0 &&
        request.resource.data.author.size() <= 80 &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.body is string &&
        request.resource.data.body.size() > 0 &&
        request.resource.data.body.size() <= 500 &&
        (
          !request.resource.data.keys().hasAny(['clientId']) ||
          (
            request.resource.data.clientId is string &&
            request.resource.data.clientId.size() > 0 &&
            request.resource.data.clientId.size() <= 120
          )
        ) &&
        request.resource.data.createdAt == request.time;
    }

    function validRatingVote(alias, userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.keys().hasAll(['alias', 'uid', 'value', 'updatedAt']) &&
        request.resource.data.keys().hasOnly(['alias', 'uid', 'value', 'updatedAt']) &&
        request.resource.data.alias == alias &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.value is int &&
        request.resource.data.value >= 1 &&
        request.resource.data.value <= 10 &&
        request.resource.data.updatedAt == request.time;
    }

    match /users/{userId}/private/{docId} {
      allow read: if owner(userId);

      allow create, update: if owner(userId) && (
        (docId == 'favorites' && validFavorites(userId)) ||
        (docId == 'progress' && validProgress(userId)) ||
        (docId == 'settings' && validSettings(userId)) ||
        (docId == 'notifications' && validNotifications(userId)) ||
        (docId == 'notification_state' && validNotificationState(userId))
      );

      allow delete: if owner(userId);
    }

    match /anime_comments/{alias} {
      allow read: if true;
      allow write: if false;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if validCommentCreate(alias);
        allow update: if false;
        allow delete: if adminClaim();
      }
    }

    match /anime_ratings/{alias} {
      allow read: if true;
      allow write: if false;

      match /votes/{userId} {
        allow read: if true;
        allow create, update: if validRatingVote(alias, userId);
        allow delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
